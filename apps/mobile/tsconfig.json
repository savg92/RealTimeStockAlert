{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "node",
    "target": "ES2020",
    "jsx": "react-native",
    "lib": ["ES2020", "DOM"],
    "ignoreDeprecations": "6.0",
    "outDir": "./dist",
    "baseUrl": ".",
    "rootDir": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@shared/*": ["../../../packages/shared/src/*"]
    },
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "types": ["jest", "react-native", "node"]
  },
  "include": ["src/**/*", "App.tsx"],
  "exclude": ["node_modules", "dist", ".expo"]
}
