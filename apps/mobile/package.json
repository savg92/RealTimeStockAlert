{
  "name": "@stock-alert/mobile",
  "version": "0.1.0",
  "private": true,
  "description": "React Native Mobile App - Real-Time Stock Alert System",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "dev": "expo start",
    "web": "expo start --web",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "build": "expo export --platform all",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src App.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@react-native/assets-registry": "^0.85.3",
    "@react-navigation/bottom-tabs": "^7.16.1",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.15.1",
    "@react-navigation/stack": "^7.9.2",
    "@stock-alert/shared": "workspace:*",
    "expo": "^55.0.24",
    "expo-asset": "~55.0.17",
    "expo-constants": "^55.0.16",
    "expo-notifications": "~55.0.23",
    "expo-splash-screen": "^55.0.21",
    "expo-status-bar": "~55.0.6",
    "nativewind": "^4.2.4",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-gifted-charts": "^1.4.76",
    "react-native-reanimated": "~4.3.1",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "~4.25.0",
    "react-query": "^3.39.3",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@testing-library/react-native": "12.9.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.41",
    "@types/react": "~19.2.14",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "^55.0.21",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.17",
    "@react-native/jest-preset": "^0.85.3",
    "prettier": "^3.8.3",
    "react-test-renderer": "19.2.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  },
  "expo": {
    "plugins": [
      [
        "nativewind/expo",
        {
          "input": "./global.css"
        }
      ]
    ]
  }
}