{
  "name": "@stock-alert/mobile",
  "version": "0.1.0",
  "private": true,
  "description": "React Native Mobile App - Real-Time Stock Alert System",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "dev": "expo start",
    "web": "expo start --web",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "build": "expo export --platform all",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "expo": "^50.0.0",
    "react": "^18.2.0",
    "react-native": "^0.73.0",
    "react-query": "^3.39.0",
    "zustand": "^4.4.0",
    "@react-navigation/native": "^6.1.0",
    "@react-navigation/bottom-tabs": "^6.5.0",
    "react-native-screens": "^3.26.0",
    "react-native-safe-area-context": "^4.7.0",
    "react-native-gifted-charts": "^1.3.0",
    "expo-notifications": "^0.21.0",
    "socket.io-client": "^4.7.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^12.3.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.50.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "typescript": "^5.3.0",
    "expo-constants": "^15.3.0"
  },
  "expo": {
    "plugins": []
  }
}
