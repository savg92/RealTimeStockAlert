{
  "name": "@stock-alert/mobile",
  "version": "0.1.0",
  "private": true,
  "description": "React Native Mobile App - Real-Time Stock Alert System",
  "main": "expo/AppEntry",
  "packageManager": "npm@10.9.3",
  "scripts": {
    "dev": "node scripts/run-android.mjs dev",
    "dev:go": "expo start",
    "web": "expo start --web",
    "android": "node scripts/run-android.mjs android",
    "e2e:android": "node scripts/e2e-stock-alert.mjs",
    "ios": "expo run:ios",
    "build": "npm run --prefix ../../packages/shared build && expo export --platform all",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src App.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native/assets-registry": "^0.85.3",
    "@react-navigation/bottom-tabs": "^7.16.1",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.15.1",
    "@react-navigation/stack": "^7.9.2",
    "@stock-alert/shared": "file:../../packages/shared",
    "expo": "^55.0.24",
    "expo-constants": "^55.0.16",
    "expo-dev-client": "~55.0.34",
    "expo-linear-gradient": "~55.0.14",
    "expo-notifications": "~55.0.23",
    "expo-secure-store": "~55.0.14",
    "expo-splash-screen": "^55.0.21",
    "expo-status-bar": "~55.0.6",
    "firebase": "^12.13.0",
    "nativewind": "^4.2.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-gifted-charts": "^1.4.76",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.4",
    "react-query": "^3.39.3",
    "socket.io-client": "^4.2.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@react-native/jest-preset": "^0.85.3",
    "@testing-library/react-native": "13.3.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.8.0",
    "@types/react": "~19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "^55.0.21",
    "eslint": "^10.4.0",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.18",
    "prettier": "^3.8.3",
    "react-test-renderer": "19.2.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "expo": {
    "install": {
      "exclude": [
        "@types/jest",
        "jest",
        "typescript",
        "expo-constants"
      ]
    },
    "plugins": [
      [
        "nativewind/expo",
        {
          "input": "./global.css"
        }
      ]
    ]
  }
}