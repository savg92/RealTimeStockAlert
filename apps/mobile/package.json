{
  "name": "@stock-alert/mobile",
  "version": "0.1.0",
  "private": true,
  "description": "React Native Mobile App - Real-Time Stock Alert System",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "dev": "expo start",
    "web": "expo start --web",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "build": "expo export --platform all",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src App.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@react-native/assets-registry": "^0.85.3",
    "@react-navigation/bottom-tabs": "^6.5.0",
    "@react-navigation/native": "^6.1.0",
    "@react-navigation/native-stack": "^6.9.0",
    "@react-navigation/stack": "^6.3.0",
    "@stock-alert/shared": "workspace:*",
    "expo": "^50.0.0",
    "expo-asset": "^55.0.17",
    "expo-constants": "^15.3.0",
    "expo-notifications": "^0.21.0",
    "expo-splash-screen": "^0.26.0",
    "expo-status-bar": "^1.10.0",
    "nativewind": "^4.0.1",
    "react": "^18.2.0",
    "react-native": "^0.73.0",
    "react-native-gesture-handler": "^2.14.0",
    "react-native-gifted-charts": "^1.3.0",
    "react-native-reanimated": "^3.6.0",
    "react-native-safe-area-context": "^4.7.0",
    "react-native-screens": "^3.26.0",
    "react-query": "^3.39.0",
    "socket.io-client": "^4.7.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.23.0",
    "@babel/preset-typescript": "^7.23.0",
    "@testing-library/react-native": "^12.3.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "babel-jest": "^29.5.0",
    "babel-plugin-module-resolver": "^5.0.0",
    "babel-preset-expo": "^10.0.0",
    "eslint": "^8.50.0",
    "jest": "^29.5.0",
    "jest-expo": "^50.0.0",
    "prettier": "^3.0.0",
    "react-test-renderer": "18.2.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0"
  },
  "expo": {
    "plugins": [
      [
        "nativewind/expo",
        {
          "input": "./global.css"
        }
      ]
    ]
  }
}
