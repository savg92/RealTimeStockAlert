# Real-Time Stock Alert Mobile App - Environment Variables
# Copy this file to .env.local and update values as needed

# API Configuration
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_SOCKET_URL=ws://localhost:3000

# Socket.io Configuration
EXPO_PUBLIC_SOCKET_RECONNECT=true
EXPO_PUBLIC_SOCKET_RECONNECT_DELAY=1000
EXPO_PUBLIC_SOCKET_RECONNECT_DELAY_MAX=5000

# Feature Flags
EXPO_PUBLIC_ENABLE_NOTIFICATIONS=true
EXPO_PUBLIC_ENABLE_OFFLINE_MODE=true
EXPO_PUBLIC_AUTH_BEARER_TOKEN=

# Optional Android FCM native config path (defaults to ./google-services.json)
EXPO_ANDROID_GOOGLE_SERVICES_FILE=./google-services.json

# Debug Mode
EXPO_PUBLIC_DEBUG=false
