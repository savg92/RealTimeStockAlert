# Mobile-specific environment example for the Expo/react-native app.
# Copy this file to `apps/mobile/.env` (or export these into your shell) and
# DO NOT commit the real `.env` file.

# Public Expo variables are accessible in the JS runtime when prefixed with
# EXPO_PUBLIC_. Add the same values without the prefix if you use a different
# loader that maps `process.env.*` directly.
EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id

# Optional: also expose plain names for non-Expo tooling
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
# Real-Time Stock Alert Mobile App - Environment Variables
# Copy this file to .env.local and update values as needed

# API Configuration
# EXPO_PUBLIC_API_URL=http://localhost:3000
# EXPO_PUBLIC_SOCKET_URL=http://localhost:3000
 EXPO_PUBLIC_API_URL=http://10.0.2.2:3000
 EXPO_PUBLIC_SOCKET_URL=http://10.0.2.2:3000

# Socket.io Configuration
EXPO_PUBLIC_SOCKET_RECONNECT=true
EXPO_PUBLIC_SOCKET_RECONNECT_DELAY=1000
EXPO_PUBLIC_SOCKET_RECONNECT_DELAY_MAX=5000

# Feature Flags
EXPO_PUBLIC_ENABLE_NOTIFICATIONS=true
EXPO_PUBLIC_ENABLE_OFFLINE_MODE=true
# Optional auth token for syncing FCM device tokens with the backend.
# Leave blank for local/dev runs; the app will use a no-op sync client.
EXPO_PUBLIC_AUTH_BEARER_TOKEN=

# Optional Android FCM native config path (defaults to ./google-services.json)
EXPO_ANDROID_GOOGLE_SERVICES_FILE=./google-services.json

# Optional Expo app metadata overrides for release builds
EXPO_APP_NAME=Real-Time Stock Alert
EXPO_SLUG=real-time-stock-alert
EXPO_ANDROID_PACKAGE=com.stockalert.mobile

# Debug Mode
EXPO_PUBLIC_DEBUG=false
