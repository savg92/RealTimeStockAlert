{
  "name": "real-time-stock-alert",
  "version": "0.1.0",
  "private": true,
  "description": "Real-Time Stock Alert System - Monorepo",
  "type": "module",
  "scripts": {
    "dev": "bun run --parallel dev:backend dev:mobile",
    "dev:backend": "bun --cwd apps/backend run dev",
    "dev:mobile": "bun --cwd apps/mobile run dev",
    "build": "bun run build:backend && bun run build:mobile && bun run build:shared",
    "build:backend": "bun --cwd apps/backend run build",
    "build:mobile": "bun --cwd apps/mobile run build",
    "build:shared": "bun --cwd packages/shared run build",
    "test": "bun run test:backend && bun run test:mobile && bun run test:shared",
    "test:backend": "bun --cwd apps/backend run test",
    "test:mobile": "bun --cwd apps/mobile run test",
    "test:shared": "bun --cwd packages/shared run test",
    "lint": "bun run lint:backend && bun run lint:mobile && bun run lint:shared",
    "lint:backend": "bun --cwd apps/backend run lint",
    "lint:mobile": "bun --cwd apps/mobile run lint",
    "lint:shared": "bun --cwd packages/shared run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "workspaces": [
    "apps/backend",
    "apps/mobile",
    "packages/shared"
  ],
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.50.0",
    "prettier": "^3.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
