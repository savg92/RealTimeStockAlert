{
  "name": "real-time-stock-alert",
  "version": "0.1.0",
  "private": true,
  "description": "Real-Time Stock Alert System - Monorepo",
  "type": "module",
  "packageManager": "bun@1.0.0",
  "scripts": {
    "dev": "bun run --parallel dev:backend dev:mobile",
    "dev:backend": "bun run --cwd apps/backend dev",
    "dev:mobile": "bun run --cwd apps/mobile dev",
    "build": "bun run build:backend && bun run build:mobile && bun run build:shared",
    "build:backend": "bun run --cwd apps/backend build",
    "build:mobile": "bun run --cwd apps/mobile build",
    "build:shared": "bun run --cwd packages/shared build",
    "test": "bun run test:backend && bun run test:mobile && bun run test:shared",
    "test:backend": "bun run --cwd apps/backend test",
    "test:mobile": "bun run --cwd apps/mobile test",
    "test:shared": "bun run --cwd packages/shared test",
    "lint": "bun run lint:backend && bun run lint:mobile && bun run lint:shared",
    "lint:backend": "bun run --cwd apps/backend lint",
    "lint:mobile": "bun run --cwd apps/mobile lint",
    "lint:shared": "bun run --cwd packages/shared lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "workspaces": [
    "apps/backend",
    "apps/mobile",
    "packages/shared"
  ],
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
